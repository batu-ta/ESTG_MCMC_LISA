import numpy as np
import matplotlib.pyplot as plt

# --- waveform_estg.py içindeki fonksiyonlar ---
def estg_phase(f, alpha_M, Mc, f_min=1e-5):
    """
    ESTG faz düzeltmesini hesaplar.
    """
    G = 6.67430e-11
    c = 299792458.0
    factor = (5.0 / 192.0) * (G * Mc / c**3)**(-5.0/3.0)
    integral = (f_min**(-5.0/3.0) - f**(-5.0/3.0))
    return alpha_M * factor * integral

def snr_estg(f, h_gr, alpha_M, Mc, Sn, f_min=1e-5):
    """
    ESTG dalga formu için SNR hesaplar.
    """
    delta_psi = estg_phase(f, alpha_M, Mc, f_min)
    h_estg = h_gr * np.exp(1j * delta_psi)
    snr2 = 4 * np.trapz(np.abs(h_estg)**2 / Sn, f)
    return np.sqrt(snr2)

def fisher_alpha_M(f, h_gr, alpha_M, Mc, Sn, f_min=1e-5):
    """
    Fisher matrisi yaklaşımı ile α_M için hassasiyeti hesaplar.
    """
    G = 6.67430e-11
    c = 299792458.0
    prefactor = (5.0 / 192.0) * (G * Mc / c**3)**(-5.0/3.0)
    dpsi_dalpha = prefactor * (f_min**(-5.0/3.0) - f**(-5.0/3.0))
    F = 4 * np.trapz((dpsi_dalpha * np.abs(h_gr))**2 / Sn, f)
    return np.sqrt(1.0 / F)

def lisa_noise(f):
    """
    LISA gürültü spektral yoğunluğu (basitleştirilmiş model).
    """
    return 1e-41 * (1 + (1e-4 / f)**2)

# --- Ana kod ---
# Frekans aralığı (LISA'nın hassas olduğu bölge)
f = np.logspace(-5, -1, 1000)  # 1e-5 Hz'den 1e-1 Hz'e
Sn = lisa_noise(f)

# Kütle parametreleri (10^6 M☉ + 10^6 M☉ MBHB)
G = 6.67430e-11
c = 299792458.0
M_sun = 1.98847e30
M1 = 1e6 * M_sun
M2 = 1e6 * M_sun
Mc = (M1 * M2)**(3/5) / (M1 + M2)**(1/5)

# GR dalga formu (basitleştirilmiş)
h_gr = 1e-22 * (f / 1e-3)**(-2/3)

# SNR hesaplama (α_M=0 için)
alpha_M = 0.0
snr = snr_estg(f, h_gr, alpha_M, Mc, Sn)
print(f"SNR (α_M=0): {snr:.1f}")

# Fisher matrisi ile α_M hassasiyeti
sigma = fisher_alpha_M(f, h_gr, alpha_M, Mc, Sn)
print(f"σ(α_M): {sigma:.2e}")

# Grafik çizimi
plt.figure(figsize=(10,6))
plt.loglog(f, np.abs(estg_phase(f, 0.001, Mc)), label='α_M=0.001')
plt.loglog(f, np.abs(estg_phase(f, 0.01, Mc)), label='α_M=0.01')
plt.xlabel('f [Hz]')
plt.ylabel('|ΔΨ| [rad]')
plt.legend()
plt.grid(True)
plt.savefig('lisa_sensitivity.png')
plt.show()

# Sonuçları özetle
print("\n--- SONUÇLAR ---")
print(f"SNR (α_M=0): {snr:.1f}")
print(f"σ(α_M): {sigma:.2e}")
print(f"Bu, LISA'nın α_M'yi {sigma:.2e} hassasiyetle ölçebileceğini gösterir.")
